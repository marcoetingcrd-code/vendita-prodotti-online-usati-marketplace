# === Unified Marketplace Hub ===

# Gemini API (https://aistudio.google.com → Get API Key)
GEMINI_API_KEY=your_gemini_api_key_here

# Telegram Bot (https://t.me/BotFather → /newbot)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Owner chat IDs (https://t.me/userinfobot per ottenerli)
# Aggiungi tutti gli owner separati da virgola
OWNER_CHAT_IDS=123456789,987654321

# Server
HOST=0.0.0.0
PORT=8000
BASE_URL=http://localhost:8000

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/marketplace.db

# Upload paths
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# Email Hub (IMAP - per ricezione notifiche marketplace)
# Usa una casella email dedicata dove convergono le notifiche
EMAIL_HUB_IMAP_HOST=imap.gmail.com
EMAIL_HUB_IMAP_USER=marketplace@tuodominio.it
EMAIL_HUB_IMAP_PASS=your_app_password_here
EMAIL_HUB_POLL_SECONDS=60
